OPENAI_API_KEY=your-openai-api-key
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional vision parser settings
OPENAI_VISION_MODEL=gpt-4o
OPENAI_VISION_TEMPERATURE=0
OPENAI_VISION_MAX_TOKENS=4096

# Optional contextualization agent settings
OPENAI_CONTEXTUALIZATION_MODEL=gpt-4o
OPENAI_CONTEXTUALIZATION_TEMPERATURE=0
OPENAI_CONTEXTUALIZATION_MAX_TOKENS=4096

# Optional extraction agent settings
OPENAI_EXTRACTION_MODEL=gpt-4o
OPENAI_EXTRACTION_TEMPERATURE=0
OPENAI_EXTRACTION_MAX_TOKENS=4096
